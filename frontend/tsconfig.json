{
  "compilerOptions": {
    "target": "ES6",                          /* Компилируем в современный, но поддерживаемый стандарт JS */
    "module": "commonjs",                     /* Стандарт модулей */
    "outDir": "./dist",                       /* Все файлы .js будут автоматически складываться в папку dist */
    "rootDir": "./",                          /* Корневая папка для поиска .ts файлов */
    "strict": true,                           /* Включаем строгую проверку типов */
    "esModuleInterop": true,                  /* Обеспечивает совместимость между модулями */
    "skipLibCheck": true,                     /* Ускоряет сборку, пропуская проверку встроенных библиотек */
    "forceConsistentCasingInFileNames": true  /* Проверка регистра в именах файлов */
  },
  "include": ["app.ts"]                       /* Указываем, какой файл собирать */
}
